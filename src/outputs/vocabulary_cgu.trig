<http://agentic-ai/resource/metadata/CGU/vocabulary/organization-01> a vosv:SuggestedProperty ;
  rdfs:label "Suggest Vocabulary organization-01" ;
  vann:preferredNamespacePrefix "foaf:" ;
  vann:preferredNamespaceUri "http://xmlns.com/foaf/0.1/" ;
