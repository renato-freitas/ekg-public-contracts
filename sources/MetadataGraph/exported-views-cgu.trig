<https://graphdb.arida.site/repositories/ekg_public_contracts/rdf-graphs/KG_METADATA> {

	################################################
	### (ExportedView)-isPartOf->(SemanticView)  ###
	################################################
	<ev/contratos_cgu> a vosv:ExportedView ;
		rdfs:label "EV Contratos_cgu"@en, 
			"VE Contratos_cgu"@pt;
		dc:description "Exports Contratos_cgu data in RDF format, enriched with the semantic view ontology."@en,
			"Exporta dados da Contratos_cgu em formato RDF, enriquecidos com a ontologia da visão semântica."@pt;
		vosv:createdAt "2025-11-22 08:10:14.072914" ;
		schema:isPartOf <sv/public_contracts> ;
		vosv:hasSpecification <evspec/contratos_cgu> ;
		vosv:hasDataGraph <evdatagraph/contratos_cgu> 
	.
	
	####################################################################
	###   (ExportedView)-vosv:hasSpecification->(EVSpec)             ###
	####################################################################
	<evspec/contratos_cgu> a vosv:ExportedViewSpecification ;
		rdfs:label "Specification of contratos_cgu EV"@en, 
			"Especificação da VE contratos_cgu"@pt;
		dc:description "Contains the metadata of the artifacts that make up the exported contratos_cgu view."@en,
			"Contém os metadados dos artefatos que compõem a visão exportada contratos_cgu."@pt;
		vosv:createdAt "2025-11-22 08:11:14.072914" ;
		vosv:hasDataSource <datasource/contratos_cgu> ;
		vosv:hasOntology <ontology/contratos_cgu> ;
		vosv:hasMappings <mappings/contratos_cgu> ;
		vosv:isPartOf <svspec/ekg_public_contract>
	.
	
	####################################################################
	###           INSTANCIANDO AS PROVENIÊNCIAS                      ###
	###       (vosvExportedView)-vosv:hasDataGraph->(vosv:DataGraph) ###
	####################################################################
	<evdatagraph/contratos_cgu> a vosv:DataGraph, prov:Entity ;
		rdfs:label "EV contratos_cgu Data Graph"@en, 
			"Grafo de dados da VE contratos_cgu"@pt ;
		sd:name "https://graphdb.arida.site/repositories/ekg_public_contract/rdf-graphs/KG_contratos_cgu" ;
		prov:wasGeneratedBy <evtransformation/contratos_cgu> ;
		prov:wasDerivedFrom <datasource/contratos_cgu>
	.
	<evtransformation/contratos_cgu> a prov:Activity ;
		rdfs:label "EV_contratos_cgu Transformation"@en, 
			"Transformação da VE_contratos_cgu"@pt ;
		prov:used <datasource/contratos_cgu> ;
		prov:hadPlan <mappings/contratos_cgu> ;
		prov:endedAtTime "2024-11-14T15:20:14Z"^^xsd:dateTime 
	.

	####################################################################
	###   INSTANCIANDO ONTOLOGIAS DAS VISÕES EXPORTADAS              ###
	###   (EVSpec)-hasOntology->(vosv:EVOntology)                    ###
	####################################################################
	<ontology/contratos_cgu> a vosv:EVOntology, vosv:DataSourceOntology ;
		rdfs:label 
			"Ontologia da contratos_cgu"@pt, 
			"Ontology of contratos_cgu"@en ;
		dc:description 
			"Contém as classes e propriedades exclusivas da visão exportada contratos_cgu"@pt,
			"Contains the classes and properties unique to the exported contratos_cgu view"@en ;
		vosv:hasClass 
			schema:Contract,     # Contract
			schema:Organization, # PublicOrganization
			foaf:Group,          # ManagementUnit
			ex:Supplier;         # Suplier
		vosv:hasProperty 
			ex:hasPublicOrganization, # hasPublicOrganization
			schema:department,        # hasManagementUnit
			schema:supplier,          # hasSupplier
			dc:identifier,    # codigoOrgao, codigoUnidadeGestora, numeroContrato, processo
			schema:name,      # nomeOrgao, nomeUnidadeGestora, nomeRazaoSocialFornecedor
			ex:cpfcnpj,       # niFornecedor
			dc:description,   # objeto
			schema:startDate, # dataVigenciaInicial
			schema:endDate,   # dataVigenciaFinal
			schema:price      # valorGlobal
	.
	
	schema:Contract     vosv:hasOntology <ontology/contratos_cgu> .
	schema:Organization vosv:hasOntology <ontology/contratos_cgu> .
	foaf:Group          vosv:hasOntology <ontology/contratos_cgu> .
	ex:Supplier         vosv:hasOntology <ontology/contratos_cgu> .
}